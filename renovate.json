{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    "group:allNonMajor",
    ":semanticCommitTypeAll(chore)",
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":disableDependencyDashboard",
    ":automergeBranch"
  ],
  "timezone": "Pacific/Auckland",
  "schedule": ["before 6am on Monday"],
  "labels": ["dependencies", "automated"],
  "assignees": ["edithatogo"],
  "packageRules": [
    {
      "description": "Publication and release-evidence paths require human review",
      "matchFileNames": [
        ".github/workflows/monthly_dynamic_archive_publication.yml",
        ".github/workflows/code_quality.yml",
        ".github/workflows/codeql.yml",
        ".github/workflows/scorecard.yml",
        ".github/workflows/osv_scan.yml",
        "scripts/build_release_evidence.py",
        "scripts/check_release_evidence.py",
        "scripts/check_metadata_packages.py",
        "scripts/check_public_surface_audit.py",
        "scripts/publication_readiness.py",
        "scripts/publish_huggingface_release.py",
        "scripts/publish_zenodo_draft.py",
        "schemas/**",
        "docs/monthly-dynamic-archive-publication.md"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "publication", "requires-review"]
    },
    {
      "groupName": "All Dependencies (Auto-merge)",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "automergeStrategy": "fast-forward",
      "commitMessagePrefix": "chore(deps):",
      "labels": ["dependencies", "automated", "auto-merge"]
    },
    {
      "groupName": "Major Dependencies (Require Review)",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "commitMessagePrefix": "chore(deps)!: ",
      "labels": ["dependencies", "major-update", "requires-review"]
    },
    {
      "groupName": "GitHub Actions (Auto-merge)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "commitMessagePrefix": "chore(ci):",
      "labels": ["dependencies", "github-actions", "automated", "auto-merge"]
    },
    {
      "groupName": "Node.js (Auto-merge)",
      "matchDatasources": ["node-version"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "commitMessagePrefix": "chore(node):",
      "labels": ["dependencies", "nodejs", "automated", "auto-merge"]
    }
  ],
  "npm": {
    "minimumReleaseAge": "0 days",
    "internalChecksFilter": "strict"
  },
  "github-actions": {
    "enabled": true
  },
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "separateMajorMinor": true,
  "separateMultipleMajor": false,
  "separateMinorPatch": true,
  "stabilityDays": 0,
  "dependencyDashboard": false,
  "suppressNotifications": ["prEditedNotification", "prAutomergedNotification"],
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "ignoreTests": false
}
